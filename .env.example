# Database connection (MariaDB 10.6)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nederland_wereldwijd
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Nederland Wereldwijd open data API
API_BASE_URL=https://opendata.nederlandwereldwijd.nl/v2
API_SOURCE=nederlandwereldwijd
API_LANG=nl

# HTTP client tuning
HTTP_TIMEOUT=30
HTTP_RETRIES=3
# Pauze (in milliseconden) tussen API-verzoeken om de bron niet te overbelasten
HTTP_THROTTLE_MS=150

# Private backend-API voor de insluitbare widget
# Gedeeld geheim (bearer-token) waarmee de widget de backend-API benadert.
# Gebruik een lange, willekeurige waarde, bijv. de uitvoer van:
#   php -r "echo bin2hex(random_bytes(32));"
WIDGET_API_TOKEN=
