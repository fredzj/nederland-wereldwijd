# Database connection (MariaDB 10.6)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nederland_wereldwijd
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Nederland Wereldwijd open data API
API_BASE_URL=https://opendata.nederlandwereldwijd.nl/v2
API_SOURCE=nederlandwereldwijd
API_LANG=nl

# HTTP client tuning
HTTP_TIMEOUT=30
HTTP_RETRIES=3
# Pauze (in milliseconden) tussen API-verzoeken om de bron niet te overbelasten
HTTP_THROTTLE_MS=150
